{
  "name": "skebify",
  "displayName": "Skebify",
  "version": "1.1.0-fork",
  "description": "A more modern version of the Skeb Button extension.",
  "author": "Mark Ignacio, idunafu",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "typecheck": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "dompurify": "^3.3.2"
  },
  "devDependencies": {
    "@wxt-dev/auto-icons": "1.1.1",
    "prettier": "^3.5.3",
    "typescript": "5.9.3",
    "wxt": "0.20.27"
  },
  "volta": {
    "node": "22.23.1",
    "yarn": "1.22.22"
  }
}
